# ─── Backend API URL ───────────────────────────────────────────────────────────
# Local:    http://localhost:5000
# Deployed: https://civicsense-api.onrender.com
VITE_API_URL=http://localhost:5000

# ─── ML Service URL ────────────────────────────────────────────────────────────
# Local:    http://localhost:8000
# Deployed: https://<your-username>-civicsense-ml.hf.space
VITE_ML_URL=http://localhost:8000

# ─── Google Maps ───────────────────────────────────────────────────────────────
# Required APIs to enable in Google Cloud Console:
#   - Maps JavaScript API
#   - Places API
#   - Geocoding API
# Get your key: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
